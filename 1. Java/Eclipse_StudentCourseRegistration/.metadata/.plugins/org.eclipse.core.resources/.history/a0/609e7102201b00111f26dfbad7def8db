    private static void sortStudentsByCGPA() {
        List<Student> students = studentManager.getStudentsSortedByCGPA();
        if (students.isEmpty()) {
            System.out.println("No students found.");
        } else {
            System.out.println("\n=== STUDENTS SORTED BY CGPA ===");
            for (Student s : students) {
                System.out.printf("ID: %d, Name: %s, CGPA: %.2f%n",
                        s.getStudentId(), s.getName(), s.getCgpa());
            }
        }
    }
    
    private static void sortProfessorsByExperience() {
        List<Professor> professors = professorManager.getProfessorsSortedByExperience();
        if (professors.isEmpty()) {
            System.out.println("No professors found.");
        } else {
            System.out.println("\n=== PROFESSORS SORTED BY EXPERIENCE ===");
            for (Professor p : professors) {
                System.out.printf("ID: %d, Name: %s, Experience: %d years%n",
                        p.getProfessorId(), p.getName(), p.getExperienceYears());
            }
        }
    }
    
    private static void sortCoursesByCredits() {
