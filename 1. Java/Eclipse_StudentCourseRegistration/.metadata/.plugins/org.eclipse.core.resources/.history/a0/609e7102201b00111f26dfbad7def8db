    private static void enrollStudent() {
        System.out.print("Enter student ID: ");
        int studentId = scanner.nextInt();
        System.out.print("Enter course code: ");
        String courseCode = scanner.next();
        scanner.nextLine(); // consume newline
        
        // Check if student exists
        Student student = studentManager.findById(studentId);
        if (student == null) {
            throw new StudentNotFoundException("Student with ID " + studentId + " not found");
        }
        
        // Check if course exists
        Course course = courseManager.findById(courseCode);
        if (course == null) {
            throw new CourseNotFoundException("Course with code " + courseCode + " not found");
        }
        
        // Check if course is full
        if (!course.enrollStudent()) {
            throw new CourseFullException("Course " + courseCode + " is already full");
        }
        
        // Create enrollment
        Enrollment enrollment = new Enrollment(0, studentId, courseCode, 
                com.university.utils.DateUtils.getCurrentDate(), 
                student.getSemester(), "Enrolled", 0.0);
        
        enrollmentManager.add(enrollment);
        System.out.println("Student enrolled successfully!");
    }
    
