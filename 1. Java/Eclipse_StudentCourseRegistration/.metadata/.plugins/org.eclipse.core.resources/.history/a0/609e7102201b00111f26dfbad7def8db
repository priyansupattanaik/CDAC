        } else {
            System.out.println("\n=== COURSES SORTED BY CREDITS ===");
            for (Course c : courses) {
                System.out.printf("Code: %s, Name: %s, Credits: %d%n",
                        c.getCourseCode(), c.getCourseName(), c.getCredits());
            }
        }
    }
    
