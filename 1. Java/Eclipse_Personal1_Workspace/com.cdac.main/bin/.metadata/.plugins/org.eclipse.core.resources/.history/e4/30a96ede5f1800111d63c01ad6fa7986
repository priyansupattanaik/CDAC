package com.cdac.main;

import java.lang.reflect.Constructor;
import java.lang.reflect.Field;
import java.lang.reflect.Method;
import java.util.OptionalInt;
import java.util.stream.IntStream;

class Test
{
	private int Num1;
	private int Num2;
	
	
	public Test()
	{
		
	}
	
	private Test(int Num1, int Num2)
	{
		this.Num1=Num1;
		this.Num2=Num2;
	}

	public int getNum1() {
		return Num1;
	}

	public void setNum1(int num1) {
		Num1 = num1;
	}

	public int getNum2() {
		return Num2;
	}

	public void setNum2(int num2) {
		Num2 = num2;
	}
	
	
}

public class Program {
	
	public static void main(String[] args) {
		
		Test t1=new Test();
		Class<?> c1=null;
			try {
				c1	=Class.forName("com.cdac.main.Test");
			} catch (ClassNotFoundException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
		Field farr[]=c1.getDeclaredFields();
		
		for(Field f:farr)
		{
			System.out.println(f+" is Accessible"+f.isAccessible());
		}
		
		
		t1.Num1=100;
		
		Field fNum1=c1.getDeclaredField("Num1");
		
		fNum1.setAccessible(true);
		fNum1.setInt(t1, 50);
		
		Field fNum2=c1.getDeclaredField("Num2");
		
		fNum2.setAccessible(true);
		fNum2.setInt(t1, 60);
		
		System.out.println(t1.getNum1());
		System.out.println(t1.getNum2());
	}
}
