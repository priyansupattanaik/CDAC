package com.cdac.main;

import java.util.ArrayList;
import java.util.Collections;
import java.util.Scanner;

import com.cdac.Mangers.EmployeeManager;

public class Program {
	
	
	
	public static void main(String[] args) {
		
		ArrayList<Integer> nlist=new ArrayList<Integer>();
		
		nlist.add(1);
		nlist.add(13);
		nlist.add(20);
		nlist.add(9);
		nlist.add(67);
		nlist.add(90);
		nlist.add(786);
		
		System.out.println(nlist);
		
		
		Collections.sort(nlist);
		
		System.out.println(nlist);
		
		
		
		nlist.stream().filter(n->n>50).forEach(e->System.out.println(e));

	}
	
	public static void main2(String[] args) {
		
		
		ArrayList list=new ArrayList<>();		//Raw Collection Type
		
		list.add(10);
		list.add("Malkeet");
		list.add(10);
		list.add("Malkeet");
		list.add(10);
		list.add(1233.67f);
		
		
		
		System.out.println(list);
		
		for(Object o:list)			//For-Each Loop
		{
			System.out.println(o);
		}
		
		list.stream().forEach(e->System.out.println(e));
		
	}

	public static void main1(String[] args) 
	{

		int choice;
		Scanner sc=new Scanner(System.in);
		EmployeeManager em=new EmployeeManager();
		
		
		do
		{
			System.out.println("======================Employee Management System======================");
			System.out.println("Press 1 to Add Employee");
			System.out.println("Press 2 to View All Employee");
			System.out.println("Press 3 to Update Employee");
			System.out.println("Press 4 to Delete Employee");
			System.out.println("Press 5 to Exit the Program");
			System.out.println("=======================================================================");
			System.out.println("Enter you choice");
			choice=sc.nextInt();
			
			switch (choice) 
			{
			case 1:
				em.AddEmployee();
				break;
			case 2:
				em.PrintEmployees();
				break;
			case 3:
				em.UpdateEmployee();
				break;
			case 4:
				em.DeleteEmployee();
				break;
			case 5:
				System.out.println("Exiting The Program! Bye Bye");
				break;
			default:
				System.out.println("Invalid Input");
				break;
			}
		}while(choice!=5);
		
		
		
	}
	

}
