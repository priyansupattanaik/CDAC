class Student
{
	int RollNO;
	String Name;
	int Age;
	float Fees;
	
	public Student() {
		super();
	}

	public Student(int rollNO, String name, int age, float fees) {
		super();
		RollNO = rollNO;
		Name = name;
		Age = age;
		Fees = fees;
	}

	@Override
	public String toString() {
		return "RollNO=" + RollNO + ", Name=" + Name + ", Age=" + Age + ", Fees=" + Fees;
	}
	
	
}

