	public static void main4(String[] args) {
		
		ArrayList<Student> slist=new ArrayList<Student>();
		
		//Student s=new Student(101, "Sandeep", 34, 34567.89f);
		
		slist.add(new Student(101, "Sandeep", 34, 34567.89f));
		slist.add(new Student(104, "Zeenat", 21, 134567.89f));
		slist.add(new Student(106, "Hritik", 20, 567.89f));
		slist.add(new Student(102, "Sohan", 78, 67.89f));
		slist.add(new Student(107, "Aniket", 27, 1233.89f));
		slist.add(new Student(105, "Ankur", 24, 1000.0f));
		slist.add(new Student(103, "Payal", 26, 1117.89f));
		
		
		System.out.println(slist);
		
		
		System.out.println("For Each Loop");
		
		for(Student s :slist)
		{
			System.out.println(s);
		}
		
		
		System.out.println("By using iterator");
		Iterator<Student> it=slist.iterator();
		
		while(it.hasNext())
		{
			System.out.println(it.next());
		}
		
		
		System.out.println("Traverse using list Iterator");
		
		ListIterator<Student> lit = slist.listIterator();
		
		while(lit.hasNext())
		{
			System.out.println(lit.next());
		}
		
		
		System.out.println("For Each Method");
		
		slist.stream().forEach(e->System.out.println(e));
	}
	
	public static void main3(String[] args) {
		
		ArrayList<Integer> nlist=new ArrayList<Integer>();
		
		nlist.add(1);
		nlist.add(13);
		nlist.add(20);
		nlist.add(9);
		nlist.add(67);
		nlist.add(90);
		nlist.add(786);
		
		System.out.println(nlist);
		
		
		Collections.sort(nlist);
		
		System.out.println(nlist);
		
		
		
		nlist.stream().filter(n->n>50).forEach(e->System.out.println(e));
		
		nlist.stream().filter(n->n>50).filter(n->n%2==0).forEach(e->System.out.println(e));

	}
	
